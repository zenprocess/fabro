+/// Decide whether a TODO event should mutate `StageProjection.todos`.
+///
+/// OpenAI plan lists are scoped per agent session (`openai_plan:<session_id>`),
+/// so a child/subagent session can emit its own list against the same stage.
+/// The stage sidebar reflects the root agent's plan, so we drop OpenAI plan
+/// events that come from child sessions (signaled by `parent_session_id` being
+/// set). Anthropic task lists are shared across sessions on the root list id,
+/// so child-session Anthropic events must still apply.
+fn should_project_stage_todo_event(stored: &RunEvent, list_kind: TodoListKind) -> bool {
+    !(list_kind == TodoListKind::OpenAiPlan && stored.parent_session_id.is_some())
+}
