+[project]
+name = "solitaire-tui"
+version = "0.1.0"
+description = "A terminal-based Klondike solitaire game in Python with a curses TUI"
+readme = "README.md"
+requires-python = ">=3.11"
+classifiers = [
+    "Programming Language :: Python :: 3",
+    "License :: OSI Approved :: MIT License",
+    "Operating System :: OS Independent",
+]
+dependencies = []
+
+[tool.pytest.ini_options]
+minversion = "6.0"
