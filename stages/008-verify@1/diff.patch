+        tokio::time::timeout(Duration::from_secs(1), receiver.recv())
+            .await
+            .expect("delivery should arrive")
+            .expect("subscription should remain open")
+            .expect("delivery should be ok")
+    }
+
+    #[tokio::test]
+    async fn messages_publish_in_order() {
