        "content": [
          {
            "type": "input_text",
            "text": "Hello"
          }
        ]
      }
    ],
    "instructions": "Be concise",
    "temperature": 0.5,
    "max_output_tokens": 128,
    "tools": [
      {
        "type": "function",
        "name": "search",
        "description": "Search files",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            }
          }
        }
      }
    ],
    "store": false,
    "include": [
      "reasoning.encrypted_content"
    ]
  }
